# Site
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME=Produk Review ID

# Supabase (admin dashboard, click tracking, newsletter)
# Buat project gratis di https://supabase.com lalu copy nilai dari Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin (untuk cek role admin sederhana berbasis email)
ADMIN_EMAILS=admin@example.com

# Google AdSense (opsional)
NEXT_PUBLIC_ADSENSE_CLIENT=

# Analytics (opsional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Push notification (opsional - OneSignal)
NEXT_PUBLIC_ONESIGNAL_APP_ID=
